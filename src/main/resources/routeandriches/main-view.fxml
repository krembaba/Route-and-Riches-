<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="routeandriches.controller.GameController"
            style="-fx-background-color: linear-gradient(to bottom, #eef4fb, #dbe6f0);">

    <top>
        <ToolBar style="-fx-background-color: linear-gradient(to right, #22313f, #2d465a); -fx-padding: 10;">
            <Button text="Start" onAction="#handleStart"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>
            <Button text="Pause" onAction="#handlePause"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>
            <Button text="Normal" onAction="#handleNormalSpeed"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>
            <Button text="Fast" onAction="#handleFastSpeed"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Route and Riches — City Builder Slice"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </ToolBar>
    </top>

    <center>
        <HBox spacing="14">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 18, 0.2, 0, 4);"
                  HBox.hgrow="ALWAYS">
                <Label text="City Map"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #22313f;"/>
                <Label text="Hover to preview placements. Build, remove, inspect and edit routes from the side panel."
                       style="-fx-text-fill: #5a6c7d;" wrapText="true"/>

                <ScrollPane fx:id="mapScrollPane"
                            pannable="true"
                            fitToWidth="false"
                            fitToHeight="false"
                            prefViewportWidth="980"
                            prefViewportHeight="420"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <Canvas fx:id="mapCanvas" width="2160" height="1440"/>
                    </content>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

    <right>
        <ScrollPane fitToWidth="true"
                    prefWidth="345"
                    hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="12" prefWidth="315"
                      style="-fx-padding: 14 14 14 0;">

                    <VBox spacing="10"
                          style="-fx-background-color: #252525; -fx-background-radius: 14; -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 18, 0.2, 0, 4);">

                        <Label text="Route and Riches"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                        <VBox spacing="6"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Game Status"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Label fx:id="stateLabel" text="State: PAUSED" style="-fx-text-fill: white;"/>
                            <Label fx:id="speedLabel" text="Speed: PAUSED" style="-fx-text-fill: white;"/>
                            <Label fx:id="timeLabel" text="Time: 0.0" style="-fx-text-fill: white;"/>
                        </VBox>

                        <VBox spacing="6"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="City Overview"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Label fx:id="moneyLabel" text="Money: 1000" style="-fx-text-fill: white;"/>
                            <Label fx:id="vehicleCountLabel" text="Vehicles: 0" style="-fx-text-fill: white;"/>
                            <Label fx:id="routeCountLabel" text="Routes: 0" style="-fx-text-fill: white;"/>
                            <Label fx:id="stopCountLabel" text="Stops: 0" style="-fx-text-fill: white;"/>
                            <Label fx:id="activeRouteLabel" text="Active Route: None" style="-fx-text-fill: #f0f0f0;"/>
                            <Label fx:id="selectedStopLabel" text="Selected Stop: None" style="-fx-text-fill: #f0f0f0;"/>
                        </VBox>

                        <VBox spacing="6"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Selected Tool"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Label fx:id="buildModeLabel" text="Mode: Build Road"
                                   style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                            <Label fx:id="hintLabel"
                                   text="Roads can be placed only on buildable land"
                                   wrapText="true"
                                   style="-fx-text-fill: #dddddd;"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Player Actions"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Button fx:id="buildRoadButton" text="Build Road" onAction="#handleBuildRoadMode"/>
                            <Button fx:id="removeRoadButton" text="Remove Road" onAction="#handleRemoveRoadMode"/>
                            <Button fx:id="placeStopButton" text="Place Stop" onAction="#handlePlaceStopMode"/>
                            <Button fx:id="removeStopButton" text="Remove Stop" onAction="#handleRemoveStopMode"/>
                            <Button fx:id="createRouteButton" text="Create Route" onAction="#handleCreateRouteMode"/>
                            <Button fx:id="editRouteButton" text="Edit Route" onAction="#handleEditRouteMode"/>
                            <Button fx:id="inspectButton" text="Inspect" onAction="#handleInspectMode"/>
                            <Button fx:id="sellVehicleButton" text="Sell Vehicle" onAction="#handleSellVehicleMode"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Vehicle Purchase"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="vehicleTypeComboBox" prefWidth="260"/>
                            <Button fx:id="buyVehicleButton" text="Buy Selected Vehicle" onAction="#handleBuyVehicleMode"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Route Editing"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Button fx:id="moveStopUpButton" text="Move Selected Stop Up" onAction="#handleMoveStopUp"/>
                            <Button fx:id="moveStopDownButton" text="Move Selected Stop Down" onAction="#handleMoveStopDown"/>
                            <Button fx:id="removeRouteStopButton" text="Remove Selected Stop From Route" onAction="#handleRemoveRouteStop"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Inspector"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Label fx:id="inspectTypeLabel" text="Object: None" style="-fx-text-fill: white;"/>
                            <Label fx:id="inspectPositionLabel" text="Position: -" style="-fx-text-fill: white;"/>
                            <Label fx:id="inspectDetailsLabel" text="Click Inspect, Sell Vehicle, or Edit Route actions to view details here."
                                   wrapText="true" style="-fx-text-fill: #dddddd;"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Save / Load"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Button text="Save" onAction="#handleSave"/>
                            <Button text="Load" onAction="#handleLoad"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Minimap"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Canvas fx:id="minimapCanvas" width="240" height="160"/>
                            <Label text="Click the minimap to jump the camera. Gray = roads, blue = stops, brown = buildings, green = parks/open land."
                                   wrapText="true"
                                   style="-fx-text-fill: #cccccc; -fx-font-size: 11px;"/>
                        </VBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </right>
</BorderPane>
