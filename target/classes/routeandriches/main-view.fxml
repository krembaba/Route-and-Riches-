<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="routeandriches.controller.GameController"
            style="-fx-background-color: linear-gradient(to bottom, #eef4fb, #dbe6f0);">

    <top>
        <ToolBar style="-fx-background-color: linear-gradient(to right, #22313f, #2d465a); -fx-padding: 10;">
            <Button text="Start" onAction="#handleStart"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>
            <Button text="Pause" onAction="#handlePause"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>
            <Button text="Normal" onAction="#handleNormalSpeed"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>
            <Button text="Fast" onAction="#handleFastSpeed"
                    style="-fx-background-radius: 8; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Route and Riches — City Builder Slice"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </ToolBar>
    </top>

    <center>
        <HBox spacing="14">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 18, 0.2, 0, 4);"
                  HBox.hgrow="ALWAYS">
                <Label text="City Map"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #22313f;"/>
                <Label text="Hover to preview placements. Build roads, place stops, then expand into routes and vehicles."
                       style="-fx-text-fill: #5a6c7d;" wrapText="true"/>

                <ScrollPane fx:id="mapScrollPane"
                            pannable="true"
                            fitToWidth="false"
                            fitToHeight="false"
                            prefViewportWidth="980"
                            prefViewportHeight="420"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <Canvas fx:id="mapCanvas" width="1600" height="1000"/>
                    </content>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

    <right>
        <ScrollPane fitToWidth="true"
                    prefWidth="320"
                    hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="12" prefWidth="290"
                      style="-fx-padding: 14 14 14 0;">

                    <VBox spacing="10"
                          style="-fx-background-color: #252525; -fx-background-radius: 14; -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 18, 0.2, 0, 4);">

                        <Label text="Route and Riches"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                        <VBox spacing="6"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Game Status"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Label fx:id="stateLabel" text="State: PAUSED"
                                   style="-fx-text-fill: white;"/>
                            <Label fx:id="speedLabel" text="Speed: PAUSED"
                                   style="-fx-text-fill: white;"/>
                            <Label fx:id="timeLabel" text="Time: 0.0"
                                   style="-fx-text-fill: white;"/>
                        </VBox>

                        <VBox spacing="6"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="City Overview"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Label fx:id="moneyLabel" text="Money: 1000"
                                   style="-fx-text-fill: white;"/>
                            <Label fx:id="vehicleCountLabel" text="Vehicles: 0"
                                   style="-fx-text-fill: white;"/>
                            <Label fx:id="routeCountLabel" text="Routes: 0"
                                   style="-fx-text-fill: white;"/>
                            <Label fx:id="stopCountLabel" text="Stops: 0"
                                   style="-fx-text-fill: white;"/>
                        </VBox>

                        <VBox spacing="6"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Selected Tool"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Label fx:id="buildModeLabel" text="Mode: Build Road"
                                   style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                            <Label fx:id="hintLabel"
                                   text="Roads can be placed only on buildable land"
                                   wrapText="true"
                                   style="-fx-text-fill: #dddddd;"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Build &amp; Transport Controls"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Button fx:id="buildRoadButton" text="Build Road" onAction="#handleBuildRoadMode"/>
                            <Button fx:id="placeStopButton" text="Place Stop" onAction="#handlePlaceStopMode"/>
                            <Button fx:id="createRouteButton" text="Create Route" onAction="#handleCreateRouteMode"/>
                            <Button fx:id="spawnBusButton" text="Spawn Bus" onAction="#handleSpawnBusMode"/>
                            <Button fx:id="spawnTramButton" text="Spawn Tram" onAction="#handleSpawnTramMode"/>
                            <Separator/>
                            <Button text="Save" onAction="#handleSave"/>
                            <Button text="Load" onAction="#handleLoad"/>
                        </VBox>

                        <VBox spacing="8"
                              style="-fx-background-color: #333333; -fx-background-radius: 10; -fx-padding: 10;">
                            <Label text="Minimap"
                                   style="-fx-text-fill: #ffd966; -fx-font-weight: bold;"/>
                            <Canvas fx:id="minimapCanvas" width="240" height="160"/>
                            <Label text="Gray = roads, blue = stops, brown = buildings, green = parks/open land."
                                   wrapText="true"
                                   style="-fx-text-fill: #cccccc; -fx-font-size: 11px;"/>
                        </VBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </right>
</BorderPane>